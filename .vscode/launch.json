{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "拾光分发 Desktop",
      "type": "debugpy",
      "request": "launch",
      "module": "sau_desktop.main",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUTF8": "1"
      },
      "justMyCode": false,
      "console": "integratedTerminal",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
    },
    {
      "name": "拾光分发 Desktop Watch",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\tools\\watch_desktop.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUTF8": "1"
      },
      "justMyCode": false,
      "console": "integratedTerminal",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
    },
    {
      "name": "拾光分发 CLI",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\sau_cli.py",
      "cwd": "${workspaceFolder}",
      "args": [],
      "env": {
        "PYTHONUTF8": "1"
      },
      "justMyCode": false,
      "console": "integratedTerminal",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
    }
  ],
  "compounds": [
    {
      "name": "拾光分发 Desktop 1.0",
      "configurations": [
        "拾光分发 Desktop"
      ],
      "stopAll": true
    }
  ]
}
